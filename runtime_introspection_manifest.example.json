{
  "runtime_build_profile": "nullcontext_instrumented_llama_server",
  "instrumentation_backend": "stdout_event_signals_v1",
  "declared_signal_ids": [
    "allocator_initialized",
    "allocator_teardown_observed",
    "allocator_reset_observed",
    "kv_cache_initialized",
    "kv_cache_reused",
    "kv_cache_clear_observed",
    "model_load_observed",
    "model_unload_observed"
  ],
  "declared_cleanup_signal_ids": [
    "allocator_reset_observed",
    "kv_cache_clear_observed",
    "model_unload_observed"
  ],
  "signal_aliases": {
    "allocator_teardown_observed": [
      "allocator_teardown"
    ],
    "allocator_reset_observed": [
      "allocator_reset"
    ],
    "kv_cache_clear_observed": [
      "kv_cache_clear"
    ],
    "model_load_observed": [
      "model_load"
    ],
    "model_unload_observed": [
      "model_unload"
    ]
  },
  "allocator_introspection_status": "allocator_lifecycle_signals_available",
  "kv_cache_introspection_status": "kv_cache_lifecycle_signals_available",
  "model_unload_signal_status": "model_unload_signal_available",
  "allocator_reset_signal_status": "allocator_reset_signal_available",
  "notes": [
    "Place a real manifest next to the configured llama-server binary using the sidecar filename pattern documented in src/runtime_capabilities.rs.",
    "This manifest declares what the runtime claims it can emit; it is not proof that a given session actually observed the lifecycle signals."
  ]
}
